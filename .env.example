# Optional. Leave unset to use same-origin `/orchestrator` and `/storage` routes.
VITE_API_BASE_URL=http://localhost:8000

# Used by `server.mjs` when serving the built app and proxying public API routes.
BACKEND_API_BASE_URL=http://localhost:8000

# Optional comma-separated allowlist for proxy preflight responses.
CORS_ALLOW_ORIGINS=http://localhost:4173,http://localhost:5173
